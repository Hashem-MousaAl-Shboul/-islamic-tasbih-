{
  "expo": {
    "name": "Sabbah",
    "slug": "islamic-dhikr",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sabbah",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4332"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.islamicdhikr.sabbah",
      "buildNumber": "101",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
        "NSPhotoLibraryUsageDescription": "This app lets you choose a custom background image from your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1B4332"
      },
      "versionCode": 108,
      "package": "app.islamicdhikr.sabbah",
      "permissions": [
        "android.permission.VIBRATE",
        "INTERNET",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "navigationBarColor": "#F7F4EE",
      "navigationBarStyle": "dark"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#D4A853",
      "androidMode": "default"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-localization",
      "expo-mail-composer",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4282819777610118~5450174392",
          "iosAppId": "ca-app-pub-4282819777610118~7403522538",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you."
        }
      ],
      "expo-audio",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36
          }
        }
      ],
      "./plugins/withKotlinMetadataCompat",
      [
        "expo-notifications",
        {
          "androidChannels": [
            {
              "id": "adhkar-reminders",
              "name": "Adhkar Reminders",
              "description": "Daily reminders for morning, evening, and after-prayer adhkar",
              "importance": "high",
              "lightColor": "#D4A853",
              "vibrationPattern": [0, 250, 250, 250]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
