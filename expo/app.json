{
  "expo": {
    "name": "سبّح - Sabbah",
    "slug": "islamic-dhikr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sabbah",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B4332"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.islamicdhikr.sabbah",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.islamicdhikr.sabbah",
      "permissions": [
        "android.permission.VIBRATE",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-localization",
      "expo-av",
      "expo-web-browser",
      "expo-mail-composer",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4282819777610118~7403522538",
          "iosAppId": "ca-app-pub-4282819777610118~7403522538"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}